{
	"name": "@steve02081504/fount-p2p",
	"version": "0.0.14",
	"description": "fount federation P2P layer — link, trust graph, mailbox, DAG, EVFS.",
	"keywords": [
		"network",
		"p2p",
		"fount",
		"AI"
	],
	"type": "module",
	"repository": {
		"type": "git",
		"url": "https://github.com/steve02081504/fount-p2p.git",
		"directory": "."
	},
	"engines": {
		"node": ">=20"
	},
	"scripts": {
		"test": "node --test --test-concurrency=1 --test-force-exit test/pure/*.test.mjs test/integration/*.test.mjs",
		"test:fount": "deno test -A --config deno.json test/fount/",
		"test:live": "node --test --test-concurrency=1 --test-force-exit test/live/*.test.mjs",
		"test:sim": "node --test --test-concurrency=1 --test-force-exit sim/test/*.test.mjs"
	},
	"files": [
		"**/*.mjs",
		"**/*.json",
		"!test/**",
		"!sim/**",
		"!scripts/**"
	],
	"bin": {
		"fount-p2p": "./infra/cli.mjs"
	},
	"exports": {
		".": "./index.mjs",
		"./infra": "./infra/service.mjs",
		"./link": "./link/providers/index.mjs",
		"./core/*": "./core/*.mjs",
		"./crypto": "./crypto/crypto.mjs",
		"./crypto/*": "./crypto/*.mjs",
		"./wire/*": "./wire/*.mjs",
		"./schemas/*": "./schemas/*.mjs",
		"./node/*": "./node/*.mjs",
		"./discovery": "./discovery/index.mjs",
		"./discovery/bt": "./discovery/bt/index.mjs",
		"./discovery/bt/*": "./discovery/bt/*.mjs",
		"./discovery/*": "./discovery/*.mjs",
		"./transport/link_registry": "./transport/link_registry.mjs",
		"./transport/user_room": "./transport/user_room.mjs",
		"./transport/group_link_set": "./transport/group_link_set.mjs",
		"./transport/node_scope": "./transport/node_scope.mjs",
		"./transport/room_scopes": "./transport/room_scopes.mjs",
		"./transport/remote_user_room": "./transport/remote_user_room.mjs",
		"./rooms/*": "./rooms/*.mjs",
		"./overlay": "./overlay/index.mjs",
		"./overlay/*": "./overlay/*.mjs",
		"./trust_graph/*": "./trust_graph/*.mjs",
		"./mailbox/*": "./mailbox/*.mjs",
		"./dag": "./dag/index.mjs",
		"./dag/*": "./dag/*.mjs",
		"./timeline/*": "./timeline/*.mjs",
		"./files/*": "./files/*.mjs",
		"./federation/*": "./federation/*.mjs",
		"./governance/*": "./governance/*.mjs",
		"./registries/*": "./registries/*.mjs",
		"./permissions": "./permissions/index.mjs",
		"./reputation/*": "./reputation/*.mjs",
		"./utils/*": "./utils/*.mjs"
	},
	"dependencies": {
		"@noble/curves": "latest",
		"node-datachannel": "latest",
		"on-shutdown": "latest",
		"ws": "latest"
	},
	"devDependencies": {
		"@steve02081504/exec": "latest"
	},
	"optionalDependencies": {
		"@stoprocent/bleno": "latest",
		"@stoprocent/noble": "latest"
	}
}
